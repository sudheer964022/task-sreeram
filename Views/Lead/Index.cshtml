        function collectBarcodeData() {
           let barcodeData = [];
           let table = document.getElementById('barcodeTableContainer').querySelector('.barcode-table');
           if (table) {
              let rows = table.querySelectorAll('tr');
              rows.forEach(row => {
                 let sampleTypeCell = row.querySelector('.sample-type');
                 let barcodeInput = row.querySelector('.enter-barcode');
                 let rebarcodeInput = row.querySelector('.reenter-barcode');

                 if (sampleTypeCell && barcodeInput && rebarcodeInput) {
                    barcodeData.push({
                       sampleTypeId: barcodeInput.getAttribute('data-sample-type-id'),
                       sampleType: sampleTypeCell.textContent.trim(),
                       barcode: barcodeInput.value.trim(),
                       rebarcode: rebarcodeInput.value.trim()
                    });
                 }
              });
           }
           return barcodeData;
        }


    function createOrderRows() {
        var selectedLeadId = $('#selLead').val().split('|')[0];
        let orderRows = [];
        let barcodeData = collectBarcodeData();
        let formData = collectFormData();
        let ordProduct = productIdsString;

        let allProductIds = new Set();
        Object.values(masterDict).forEach(dict => {
            dict.productIds.forEach(id => allProductIds.add(id));
        });
        ordProduct = ',' + Array.from(allProductIds).join(',');
        let myprofileMap = {};
        Object.values(masterDict).forEach(dict => {
            dict.productIds.forEach(id => {
                myprofileMap[id] = dict.myprofileId || '0';
            });
        });

        let myprofile = Array.from(allProductIds).map(id => myprofileMap[id]).join(',');
        Object.keys(sampleProduct).forEach(sampleTypeId => {
            let profiles = sampleProduct[sampleTypeId].join(',');
            let barcodeInfo = barcodeData.find(data => data.sampleTypeId === sampleTypeId);
            var sourceName = $('#selSource option:selected').text().toUpperCase().trim();
            var crsId = 0;

            if (sourceName === 'CRS' || sourceName.includes('CRS') ||
                sourceName === 'CUSTOMER REFERRAL SCHEME' || sourceName.includes('CUSTOMER REFERRAL')) {
                crsId = parseInt($('#selCRSPartner').val()) || 0;
            }

            let row = {
                CustomerTitle: formData.title,
                CustomerFirstName: formData.cusName,
                CustomerMiddleName: formData.middleName,
                CustomerLastName: formData.lastName,
                dob: formData.dob,
                isvip: document.getElementById("isVip").checked ? 1 : 0,
                newTChecked: "",
                uidNo: "",
                CusAge: parseInt(formData.age) || 0,
                CusAgeType: formData.ageType,
                CusGen: parseInt(formData.gen) || 0,
                CusCollecTime: formData.colTime,
                CusRefDr: formData.refDr,
                Mobile: formData.mob,
                Email: formData.email,
                CusCpr: formData.cpr,
                Address: formData.address,
                alertId: 0,
                nationId: parseInt(formData.nat) || 0,
                OrdProduct: ordProduct,
                profiles: profiles,
                barcode: barcodeInfo ? barcodeInfo.barcode : '',
                rebarcode: barcodeInfo ? barcodeInfo.rebarcode : '',
                labId: 1,
                srvChrg: 0,
                sampleTypeId: parseInt(sampleTypeId),
                cusId: 0,
                dis: formData.cashier,
                payMode: parseInt(formData.paymentMode) || 0,
                cardType: parseInt(formData.paymentMode) == 2 ? parseInt(formData.cardType) : 0,
                authCode: formData.authorizationCode,
                amount: 0,
                homeCharge: parseFloat(formData.homeVisitCharges.split(' ')[0]) || 0.00,
                additionalCharge: 0,
                ordDate: "",
                sampleType: barcodeInfo ? barcodeInfo.sampleType : "",
                passPort: formData.passPort,
                fileNo: formData.fileNo,
                caseId: formData.caseId,
                notId: formData.notId,
                civilId: formData.civilId,
                region: formData.region,
                wilayat: formData.wilayat,
                couponCode: formData.coupon,
                newConf: parseInt(formData.newConf) || 0,
                clientId: 0,
                btech: parseInt(formData.btech) || 0,
                sourceId: parseInt(formData.source) || 0,
                leadId: parseInt($('#selLead').val()),
                appliedCoupon: formData.appliedCoupon,
                myprofile: myprofile,
                isTravellor: document.getElementById("chktravel").checked ? 1 : 0,
                crsPartnerId: crsId
            };

            orderRows.push(row);
        });

        return orderRows;
    }

         function doEntry() {
            var leadId = $('#selLead').val().split('|')[0];
            var dobField = document.getElementById("dobPicker").value;
            var emiratesIdField = document.getElementById("txtNIN1");
            var passportField = document.getElementById("txtPassport").value.trim();
            let isTravellerChecked = document.getElementById("chktravel").checked;
            var rplid = '@Accessor.HttpContext.Session.GetInt32("RPLId")';
            let formData = collectFormData();

            if (formData.cusName.length === 0) {
                alert("Please Enter Customer Name.");
                document.getElementById("txtCusName").focus();
                return;
            } else if (formData.age.length === 0 || formData.age === 0) {
                alert("Please select Date of Birth.");
                document.getElementById("dobPicker").focus();
                return;
            } else if (formData.ageType === "0") {
                alert("Please select Customer Age Type.");
                document.getElementById("selAgeTy").focus();
                return;
            } else if (formData.gen === 0 && !document.getElementById('selOther').checked) {
                alert("Please select Customer Gender.");
                document.getElementById('selMale').focus();
                return;
            } else if (!isTravellerChecked && formData.cpr.length === 0) {
                var idLabel = document.getElementById('lblNIN') ? document.getElementById('lblNIN').textContent.replace('*', '').trim() : 'Emirates ID / CPR No';
                alert("Resident / Local patients require a valid " + idLabel + ". If this patient is a Tourist / Guest, please select Tourist / Guest.");
                document.getElementById("txtNIN1").focus();
                return;
            } else if (isTravellerChecked && passportField === "") {
                alert("Tourist / Guest patients require a Passport Number.");
                document.getElementById("txtPassport").focus();
                return;
            } else if (formData.colTime.length === 0) {
                alert("Please Enter Sample collection time.");
                document.getElementById("txtColTime").focus();
                return;
            } else if (formData.cashier === "0") {
                alert("Please select a cashier.");
                document.getElementById("selCashier").focus();
                return;
            } else if (formData.email === '' || formData.email == 0) {
                alert("Please enter Email.");
                document.getElementById("txtEmail").focus();
                return;
            } else if (!validateEmail()) {
                alert("Please enter a valid email address (e.g. name@domain.com).");
                document.getElementById("txtEmail").focus();
                return;
            } else if (!isOtherCountryB2C && !phoneIsValidB2C) {
                alert("Please enter a valid mobile number.");
                document.getElementById("txtMob").focus();
                return;
            } else if (formData.address.length < 10) {
                alert("Address must be at least 10 characters.");
                document.getElementById("txtAddress").focus();
                return;
            } else if ((formData.source === '' || formData.source == 0) && leadId == 0) {
                alert("Please Select source.");
                document.getElementById("selSource").focus();
                return;
            } else if (IsOmCov === true && formData.civilId.length === 0 && formData.passPort.length === 0) {
                alert("Please Enter either Passport No or Civil Id.");
                if (formData.civilId.length === 0) {
                    document.getElementById("txtCivilId").focus();
                } else if (formData.passPort.length === 0) {
                    document.getElementById("txtPassport").focus();
                }
                return;
                } else if (!isTravellerChecked && emiratesIdField.value && clCntry == '4') {
        var eid = emiratesIdField.value.trim();
        if (eid.length !== 15) {
            alert("Emirates ID must be exactly 15 digits.");
            emiratesIdField.focus();
            return;
        }
        if (!validateEmirateID(eid)) {
            var eidErr = '';
            if (!eid.startsWith('784')) {
                eidErr = 'Emirates ID must start with 784.';
            } else {
                var eidYr = parseInt(eid.substring(3, 7), 10);
                if (eidYr < 1900 || eidYr > 2099) {
                    eidErr = 'Emirates ID digits 4–7 must be a valid birth year (e.g. 2000).';
                } else {
                    eidErr = 'Emirates ID last 8 digits cannot all be the same digit (e.g. 11111111, 22222222).';
                }
            }
            alert(eidErr);
            emiratesIdField.focus();
            return;
        }
        if (dobField) {
            var dobParts = dobField.split('/');
            if (dobParts.length === 3) {
                var dobYearFromField = dobParts[2];
                var eidYearStr = eid.substring(3, 7);
                var rplid = '@Accessor.HttpContext.Session.GetInt32("RPLId")';
                if (dobYearFromField !== eidYearStr && rplid == 6) {
                    alert("Emirates ID year (" + eidYearStr + ") does not match Date of Birth year (" + dobYearFromField + "). Please check.");
                    return;
                }
            }
        }
    }

            if (isCRSLead && (!crsPartnerId || crsPartnerId === 0)) {
                alert("Please select a CRS Partner");
                document.getElementById("selCRSPartner").focus();
                return;
            }

            var sourceId = $('#selSource').val();
            var sourceName = $('#selSource option:selected').text().toUpperCase().trim();
            if (sourceName === 'CRS' || sourceName.includes('CRS') ||
                sourceName === 'CUSTOMER REFERRAL SCHEME' || sourceName.includes('CUSTOMER REFERRAL')) {
                var selectedCRSPartner = $('#selCRSPartner').val();
                if (!selectedCRSPartner || selectedCRSPartner === '0' || selectedCRSPartner === 0) {
                    alert("Please select a CRS Partner when source is CRS.");
                    document.getElementById("selCRSPartner").focus();
                    return;
                }
            }

            if (parseInt(leadId) !== 0) {
                var userGender = $('input[name="gender"]:checked').val();
                var userAge = formData.age;
                var userAgeType = formData.ageType;
                var userAgeInDays = convertToDays(userAge, userAgeType);
                if (userAgeInDays === null) {
                    alert("Invalid age type. Please select Years, Months, or Days.");
                    return;
                }
                var invalidTests = [];
                Object.values(masterDict).forEach(function (productData) {
                    productData.productIds.forEach(function (productId) {
                        var productDetails = selectedItems.find(item => item.productId === productId);
                        if (productDetails) {
                            var genderValidation = validateGender(productDetails, userGender);
                            if (!genderValidation.isValid) {
                                invalidTests.push(`${productDetails.productCode || productDetails.productId} - Invalid gender`);
                            }
                            var ageValidation = validateAge(productDetails, userGender, userAgeInDays);
                            if (!ageValidation.isValid) {
                                var minAgeStr = convertDaysToReadableAge(ageValidation.minAge);
                                var maxAgeStr = convertDaysToReadableAge(ageValidation.maxAge);
                                invalidTests.push(`${productDetails.productCode || productDetails.productId} - Age range should be ${minAgeStr} to ${maxAgeStr}`);
                            }
                        }
                    });
                });
                if (invalidTests.length > 0) {
                    alert("The following tests are not valid for this customer:\n\n" + invalidTests.join("\n"));
                    return;
                }
                var allProductIds = [];
                Object.values(masterDict).forEach(function (productData) {
                    allProductIds = allProductIds.concat(productData.productIds);
                });
                if (checkRBSPPBSConflict('', allProductIds)) {
                    alert("RBS and PPBS cannot be ordered at the same time. Please modify your selection.");
                    return;
                }
            }

            let barcodeTable = document.getElementById('barcodeTableContainer').querySelector('.barcode-table');
            if (barcodeTable) {
                let barcodeData = collectBarcodeData();
                for (let data of barcodeData) {
                    if (data.barcode.length != 8 && data.barcode.length != 10) {
                        alert('Please enter valid Barcode for ' + data.sampleType);
                        document.querySelector(`input[data-sample-type-id="${data.sampleTypeId}"].enter-barcode`).focus();
                        return;
                    } else if (data.rebarcode.length != 8 && data.rebarcode.length != 10) {
                        alert('Please re-enter valid Barcode for ' + data.sampleType);
                        document.querySelector(`input[data-sample-type-id="${data.sampleTypeId}"].reenter-barcode`).focus();
                        return;
                    } else if (data.barcode.toUpperCase() !== data.rebarcode.toUpperCase()) {
                        alert('Entry & Re-entry barcodes not matching for ' + data.sampleType);
                        document.querySelector(`input[data-sample-type-id="${data.sampleTypeId}"].reenter-barcode`).focus();
                        return;
                    }
                }

                let currentAmount = parseFloat(document.getElementById("amt").textContent.split(' ')[0]) || 0;
                let msb = window.msb || 0;
                let hasOutlabTest = selectedItems.some(item => item.labId != 1);

                if (msb > 0 && currentAmount < msb && !hasOutlabTest) {
                    showMinimumBillingModal(currentAmount, msb, globalCurrencyCode, globalDecimalPoints);
                } else {
                    let orderRows = createOrderRows();
                    submitOrder(orderRows);
                }
            } else {
                alert("No barcode found. Please select Test/Profile to proceed.");
                document.getElementById("selectTestProfileButton").focus();
            }
        }

            function submitOrder(orderRows) {
            var r = confirm("Please confirm to Submit this..");
            if (r == true) {
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("B2COrderEntry")',
                    data: JSON.stringify(orderRows),
                    contentType: "application/json; charset=utf-8",
                    dataType: "json",
                    success: function (response) {
                        if (response._resId == "1") {
                            alert('Order Entry done Successfully.');
                            window.location.href = '@Url.Action("lead", "Order")';
                        } else {
                            alert(response._resMsg);
                        }
                    },
                    failure: function (response) {
                        alert(response.responseText);
                    },
                    error: function (response) {
                        alert("Application Error, please try after some time .");
                    }
                });
            }
        }

        function getBalance() {
        pUrl = '@Url.Action("getBalance", "Order")';
        $.ajax({
            type: "GET",
            url: pUrl,
            contentType: "application/json; charset=utf-8",
            dataType: "json",
               success: function (response) {
                    if (response.isCash == 1) {
                        window.msb = response.msb || 0;
                    } else {
                        window.msb = 0;
                    }

                    if (rateType == 2 && isDiscountEligible == 1 && response.discountSlabs && response.discountSlabs.length > 0) {
                        discountSlabs = response.discountSlabs.sort((a, b) => a.thresholdAmount - b.thresholdAmount);
                        initializeTierDisplay();
                        $('.bg-gradient-to-r.from-purple-50').show();
                    } else {
                        discountSlabs = [];
                        $('#discountAppliedCard').hide();
                        $('#unlockDiscountCard').hide();
                        $('.bg-gradient-to-r.from-purple-50').hide();
                    }
                },
            failure: function (response) {
                alert(response.responseText);
            },
            error: function (response) {
                alert("Invalid selection");
            }
        });
    }

            function showMinimumBillingModal(currentAmount, msb, currencyCode, decimalPoints) {
            scrollToTop();
            let difference = msb - currentAmount;
            let formattedCurrent = currentAmount.toFixed(decimalPoints) + ' ' + currencyCode;
            let formattedMSB = msb.toFixed(decimalPoints) + ' ' + currencyCode;
            let formattedDifference = difference.toFixed(decimalPoints) + ' ' + currencyCode;
            document.getElementById("msbCurrentAmount").textContent = formattedCurrent;
            document.getElementById("msbMinAmount").textContent = formattedMSB;
            document.getElementById("msbDifference").textContent = formattedDifference;
            document.getElementById("msbProceedAmount").textContent = formattedMSB;
            document.getElementById("msbButtonAmount").textContent = formattedMSB;
            let modal = document.getElementById("minimumBillingModal");
            modal.style.display = "flex";
            document.body.style.overflow = "hidden";

            setTimeout(() => {
                modal.classList.add("show");
            }, 50);
        }

        function closeMinimumBillingModal() {
            let modal = document.getElementById("minimumBillingModal");
            modal.classList.remove("show");
            document.body.style.overflow = "auto";

            setTimeout(() => {
                modal.style.display = "none";
            }, 300);
        }

       function proceedWithMinimumBilling() {
        closeMinimumBillingModal();
        let orderRows = createOrderRows();
        submitOrder(orderRows);
    }
        function scrollToTop() {
            const mainPanel = document.querySelector('.main-panel');
            const contentWrapper = document.querySelector('.content-wrapper');

            if (mainPanel) {
                mainPanel.scrollTo({ top: 0, behavior: 'smooth' });
                mainPanel.scrollTop = 0;
            }

            if (contentWrapper) {
                contentWrapper.scrollTo({ top: 0, behavior: 'smooth' });
                contentWrapper.scrollTop = 0;
            }

            window.scrollTo({ top: 0, behavior: 'smooth' });
            document.documentElement.scrollTop = 0;
            document.body.scrollTop = 0;
        }

        function updateDiscountVisibility() {
        var discountTierCard = document.querySelector('.bg-gradient-to-r.from-purple-50');
        var discountAppliedCard = document.getElementById('discountAppliedCard');
        var unlockDiscountCard = document.getElementById('unlockDiscountCard');

        if (isDiscountEligible == 0 || rateType != 2) {
            if (discountTierCard) discountTierCard.style.display = 'none';
            if (discountAppliedCard) discountAppliedCard.style.display = 'none';
            if (unlockDiscountCard) unlockDiscountCard.style.display = 'none';
            appliedDiscount = {
                percentage: 0,
                amount: 0,
                enabled: false,
                tier: 0
            };
        } else {
            if (discountTierCard) discountTierCard.style.display = 'block';
        }
    }
        function loadCRSPartners(locationId, selectedCrsId) {
            return new Promise(function(resolve, reject) {
                $.ajax({
                    url: '@Url.Action("GetCRSPartners", "Lead")',
                    type: 'POST',
                    data: {
                        locationId: locationId,
                        isActive: 1,
                        globalSearch: null
                    },
                    dataType: "json",
                    success: function(response) {
                        var $select = $('#selCRSPartner');
                        $select.empty().append('<option value="0">Select CRS Partner</option>');

                        if (response.success && response.data && response.data.length > 0) {
                            $.each(response.data, function(i, p) {
                                $select.append(
                                    '<option value="' + p.id + '" data-name="' + p.crsName + '">' +
                                    p.crsName + ' (' + p.crsCode + ')' +
                                    '</option>'
                                );
                            });
                            if (selectedCrsId && selectedCrsId > 0) {
                                $select.val(selectedCrsId);
                                var leadId = ($('#selLead').val() || '').split('|')[0] || 0;
                                if (leadId != 0) {
                                    $select.prop('disabled', true);
                                }
                                crsPartnerName = $select.find('option:selected').data('name') || '';
                            }
                        }

                        resolve();
                    },
                    error: function() {
                        resolve();
                    }
                });
            });
        }
    
    function updateNINLabelForCountry(clCntryVal) {
        var labelMap = {
            4: 'Emirates ID',
            2: 'CPR No',
            1: 'CPR No',
            5: 'IQAMA No',
            3: 'Civil ID'
        };
        var placeholderMap = {
            4: 'Emirates Id *',
            2: 'CPR No *',
            1: 'CPR No *',
            5: 'IQAMA No *',
            3: 'Civil ID *'
        };
        var label = labelMap[clCntryVal] || 'National ID';
        var placeholder = placeholderMap[clCntryVal] || 'National ID *';

        var lblNIN = document.getElementById('lblNIN');
        if (lblNIN) {
            var isTourist = document.getElementById('chktravel')
                ? document.getElementById('chktravel').checked
                : false;
            lblNIN.textContent = label + (isTourist ? ' (Optional)' : ' *');
        }

        var txtNIN1 = document.getElementById('txtNIN1');
        if (txtNIN1) txtNIN1.setAttribute('placeholder', placeholder);
    }

        function updateTotalDisplay() {
            const totalAmountSpan = document.getElementById('totDisPrice');
            const testAmount = parseFloat(document.getElementById('amt').innerHTML.split(' ')[0]) || 0;
            var customerMode = parseInt(document.getElementById('customerMode').value);
            var txtHomeCharge = document.getElementById('txtHomeCharge').value;
            var homeCharge = 0;
            var dis = $('#seldistance').val();

            if (customerMode == '2' && txtHomeCharge && txtHomeCharge.split(' ')[0] != '0') {
                homeCharge = parseFloat(txtHomeCharge.split(' ')[0]) || 0;
            } else {
                homeCharge = dis != '0' ? parseFloat((txtHomeCharge || '0').split(' ')[0]) || 0 : 0;
            }

            let discountAmount = 0;
            let total = testAmount + homeCharge;

            if (rateType == 2) {
                if (isCRSLead && crsPartnerId > 0) {
                    discountAmount = crsDiscount || 0;
                } else if (appliedDiscount.enabled && appliedDiscount.percentage > 0) {
                    discountAmount = (testAmount * appliedDiscount.percentage) / 100;
                }
                total = (testAmount - discountAmount) + homeCharge;
            }

            if (CoupnCodeApplied) {
                totalAmountSpan.textContent = (0).toFixed(globalDecimalPoints) + ' ' + globalCurrencyCode;
            } else {
                totalAmountSpan.textContent = total.toFixed(globalDecimalPoints) + ' ' + globalCurrencyCode;
            }
        }
</script>