    function validateEmirateID(id) {
        if (!/^\d{15}$/.test(id)) return false;

        if (!id.startsWith('784')) return false;

        var yearPart = parseInt(id.substring(3, 7), 10);
        if (yearPart < 1900 || yearPart > 2099) return false;

        var last8 = id.substring(7);
        if (/^(\d)\1{7}$/.test(last8)) return false;

        return true;
    }

