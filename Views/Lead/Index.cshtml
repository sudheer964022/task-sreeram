                $('#dvCRSDiscountBanner').removeClass('show');
                $('#dvCRSInfoTag').removeClass('show');

                var discountTierCard = document.querySelector('.bg-gradient-to-r.from-purple-50');
                if (discountTierCard) discountTierCard.style.display = 'none';

                updateTierHighlight(0);
                appliedDiscount = { percentage: 0, amount: 0, enabled: false, tier: 0 };
                crsDiscount = 0;
                calculateTotal();
                return;
            }

            const testAmountText = document.getElementById('amt').textContent;
            const testAmount = parseFloat(testAmountText.split(' ')[0]) || 0;

            const discountCard = document.getElementById('discountAppliedCard');
            const unlockCard = document.getElementById('unlockDiscountCard');

            if (isCRSLead) {
                discountCard.classList.add('hidden');
                discountCard.style.display = 'none';
                unlockCard.classList.add('hidden');
                unlockCard.style.display = 'none';
                $('.tier-item').addClass('crs-disabled');

                var discountTierCard = document.querySelector('.bg-gradient-to-r.from-purple-50');
                if (discountTierCard) discountTierCard.style.display = 'none';

                if (crsPartnerId > 0 && testAmount > 0) {
                    crsDiscount = (testAmount * 20) / 100;
                    crsDiscount = Math.round(crsDiscount * Math.pow(10, globalDecimalPoints)) / Math.pow(10, globalDecimalPoints);

                    appliedDiscount = { percentage: 20, amount: crsDiscount, enabled: true, tier: 0 };

                    $('#lblCRSCartAmount').text(testAmount.toFixed(globalDecimalPoints) + ' ' + globalCurrencyCode);
                    $('#lblCRSSavings').text(crsDiscount.toFixed(globalDecimalPoints) + ' ' + globalCurrencyCode);
                    $('#dvCRSDiscountBanner').addClass('show');
                    $('#dvCRSInfoTag').addClass('show');
                } else {
                    crsDiscount = 0;
                    appliedDiscount = { percentage: 0, amount: 0, enabled: false, tier: 0 };
                    $('#dvCRSDiscountBanner').removeClass('show');
                    $('#dvCRSInfoTag').removeClass('show');
                }

                calculateTotal();
                return;
            }

            crsDiscount = 0;
            $('#dvCRSDiscountBanner').removeClass('show');
            $('#dvCRSInfoTag').removeClass('show');
            $('.tier-item').removeClass('crs-disabled');

            if (discountSlabs.length === 0) {
                discountCard.classList.add('hidden');
                unlockCard.classList.add('hidden');
                updateTierHighlight(0);
                appliedDiscount = { percentage: 0, amount: 0, enabled: false, tier: 0 };
                calculateTotal();
                return;
            }

            const discountInfo = calculateApplicableDiscount(testAmount);

            if (discountInfo.percentage > 0 && testAmount > 0) {
                const discountAmount = (testAmount * discountInfo.percentage) / 100;

                updateTierHighlight(discountInfo.tier);

                document.getElementById('discountPercentageLabel').textContent = discountInfo.percentage + '%';
                document.getElementById('discountAmountLabel').textContent = discountAmount.toFixed(globalDecimalPoints) + ' ' + globalCurrencyCode;
                document.getElementById('discountTestAmount').textContent = testAmount.toFixed(globalDecimalPoints) + ' ' + globalCurrencyCode;
                document.getElementById('discountFinalTotal').textContent = (testAmount - discountAmount).toFixed(globalDecimalPoints) + ' ' + globalCurrencyCode;

                discountCard.classList.remove('hidden');
                discountCard.style.display = 'block';

                if (discountInfo.nextThreshold && discountInfo.amountNeeded > 0) {
                    let displayAmount = discountInfo.amountNeeded.toFixed(globalDecimalPoints) + ' ' + globalCurrencyCode;
                    let nextPercentage = discountInfo.nextThreshold.discountPercentage;
                    document.getElementById('unlockMainMessage').innerHTML = `Add ${displayAmount} more to unlock <strong>${nextPercentage}%</strong> discount!`;
                    unlockCard.classList.remove('hidden');
                    unlockCard.style.display = 'block';
                } else {
                    unlockCard.classList.add('hidden');
                    unlockCard.style.display = 'none';
                }

                appliedDiscount = {
                    percentage: discountInfo.percentage,
                    amount: discountAmount,
                    enabled: true,
                    tier: discountInfo.tier,
                    nextTierIndex: discountInfo.nextTierIndex,
                    nextThreshold: discountInfo.nextThreshold,
                    amountNeeded: discountInfo.amountNeeded
                };

            } else if (discountInfo.nextThreshold && testAmount > 0) {
                updateTierHighlight(0);

                let displayAmount = discountInfo.amountNeeded.toFixed(globalDecimalPoints) + ' ' + globalCurrencyCode;
                let nextPercentage = discountInfo.nextThreshold.discountPercentage;
                document.getElementById('unlockMainMessage').innerHTML = `Add ${displayAmount} more to unlock <strong>${nextPercentage}%</strong> discount!`;

                unlockCard.classList.remove('hidden');
                unlockCard.style.display = 'block';
                discountCard.classList.add('hidden');
                discountCard.style.display = 'none';

                appliedDiscount = {
                    percentage: 0,
                    amount: 0,
                    enabled: false,
                    tier: 0,
                    nextTierIndex: discountInfo.nextTierIndex,
                    nextThreshold: discountInfo.nextThreshold,
                    amountNeeded: discountInfo.amountNeeded
                };

            } else {
                discountCard.classList.add('hidden');
                discountCard.style.display = 'none';
                unlockCard.classList.add('hidden');
                unlockCard.style.display = 'none';
                updateTierHighlight(0);
                appliedDiscount = { percentage: 0, amount: 0, enabled: false, tier: 0 };
            }

            calculateTotal();
