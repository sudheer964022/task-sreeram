           function processProducts(productIds, productCodes) {
              var newTests = [];
              var allProductTests = [];
              var sampleTypeIds = [];
              var sampleDetails = [];
              var allProfiles = [];

              function processSingleProduct(productId, productCode) {
                 return new Promise((resolve, reject) => {
                    getSampleType(productId, function (response) {
                       if (response && response.d) {
                          response.d.forEach(function (sample) {
                             if (!sampleTypeIds.includes(sample.sampletypeid)) {
                                sampleTypeIds.push(sample.sampletypeid);

                                if (!uniqueSampleTypeIds.includes(sample.sampletypeid)) {
                                   uniqueSampleTypeIds.push(sample.sampletypeid);
                                }
                             }

                             var sampleTests = sample.tests.split(',').map(test => test.trim());
                             allProductTests = allProductTests.concat(sampleTests);

                             sampleTests.forEach(function (test) {
                                if (!newTests.includes(test)) {
                                   newTests.push(test);
                                }
                             });
                             if (sample.profiles) {
                                var profileList = sample.profiles.split(',').map(profile => profile.trim());
                                allProfiles = allProfiles.concat(profileList);
                             }

                             if (sample.profiles) {
                                if (!sampleProduct[sample.sampletypeid]) {
                                   sampleProduct[sample.sampletypeid] = [];
                                }
                                let profileList = sample.profiles.split(',').map(profile => profile.trim());
                                sampleProduct[sample.sampletypeid] = [...new Set([...sampleProduct[sample.sampletypeid], ...profileList])];
                             }

                             sampleDetails.push({
                                uuid: product.uuid,
                                sampleType: sample.sampletype,
                                sampleTypeId: sample.sampletypeid,
                                tests: sample.tests,
                                profiles: sample.profiles,
                                productId: productId,
                                ...product
                             });
                          });
                          checkOmanCovid(productIds);
                          resolve();
                       } else {
                          reject("No sample type found for product: " + productId);
                       }
                    });
                 });
              }

              Promise.all(productIds.map((productId, index) => processSingleProduct(productId, productCodes[index])))
                 .then(() => {
                    var redundantProducts = new Set();
                    let subsetalert = true;
                    Object.keys(masterDict).forEach(function (existingUuid) {
                       if (existingUuid !== product.uuid && subsetalert) {
                          if (isSubset(masterDict[existingUuid].tests, newTests)) {
                             redundantProducts.add(existingUuid);
                          } else if (isSubset(newTests, masterDict[existingUuid].tests)) {
                             alert("The selected product/profile is a subset of an already selected product/profile. Please select a different one.");
                             selectedOptions = selectedOptions.filter(option => option !== newlySelectedOption);
                             if (isLead == '0') {
                                $('#selTest').val(selectedOptions).trigger('change.select2');
                             }
                             previousSelection = selectedOptions;
                             alertTriggered = true;
                             subsetalert = false;
                             return;
                          }
                       }
                    });
                    subsetalert = true;

                    if (alertTriggered) return;

                    if (newTests.length === 0) {
                       alert("All tests for this product/profile are already available in another selection. Please select a different one.");
                       selectedOptions = selectedOptions.filter(option => option !== newlySelectedOption);
                       if (isLead == '0') {
                          $('#selTest').val(selectedOptions).trigger('change.select2');
                       }
                       previousSelection = selectedOptions;
                       alertTriggered = true;
                       return;
                    }
                    masterDict[product.uuid] = {
                       productIds: productIds,
                       sampleTypeIds: sampleTypeIds,
                       tests: newTests,
                       myprofileId: product.isMyProfile === '1' ? product.productId : '0',
                       profiles: allProfiles
                    };
                    selectedItems = selectedItems.concat(sampleDetails);
                    if (redundantProducts.size > 0) {
                       redundantProducts.forEach(function (redundantUuid) {
                          handleDeselection(selectedOptions.find(option => option.split('|')[0] === redundantUuid));
                          selectedOptions = selectedOptions.filter(option => option.split('|')[0] !== redundantUuid);
                       });
                       if (isLead == '0') {
                          $('#selTest').val(selectedOptions).trigger('change.select2');
                       }
                       alert("Some previously selected products were removed as their tests are now included in the newly selected product/profile.");
                       previousSelection = selectedOptions;
                    }

                    updateSampleList(selectedItems[selectedItems.length - 1]);
                    if ($('#selTest').val() && $('#selTest').val().length === 1 && product.isMyProfile == '0' && $('#selLead').val().split('|')[0] == 0 && document.getElementById("selref").value.trim() == 0) {

                       walkinValidecoupon(product.productId);
                       $('#couponContainer').show();
                    } else {
                         $('#couponContainer').hide();
                       $('#couponContainerspan').empty();
                       $('#couponContainerspan').hide();
                       $('#txtcoupon').val('')
                       CoupnCodeApplied = false;

                    }
                    updateBarcodeTable();
                    console.log(allTests);
                    console.log(selectedItems);
                    console.log(masterDict);
                    console.log(sampleProduct);

                 })
                 .catch((error) => {
                    alert(error);
                 });
           }

           if (product.isMyProfile == '1') {
              var pUrl = '@Url.Action("getMyProfileInfo")';
              $.ajax({
                 type: "POST",
                 url: pUrl,
                 data: {
                    ProductId: product.productId
                 },
                 contentType: "application/x-www-form-urlencoded",
                 dataType: "json",
                 success: function (response) {
                    if (response && response.ordlst.length > 0) {
                       var productIds = response.ordlst.map(item => item.produtid);
                       var productCode = response.ordlst.map(item => item.profiles);
                       processProducts(productIds, productCode);
                    } else {
                       alert("No products found in the profile.");
                    }
                 },
                 error: function (response) {
                    alert("Error fetching profile data for product: " + product.productId);
                 }
              });
           } else {
              processProducts([product.productId], [product.productCode]);
           }


        }

        function isSubset(arr1, arr2) {
           return arr1.every(item => arr2.includes(item));
        }

        function handleDeselection(deselectedOption) {
           var details = deselectedOption.split('|');
           var deselectedUuid = details[0];

           if (masterDict[deselectedUuid]) {
              masterDict[deselectedUuid].sampleTypeIds.forEach(sampleTypeId => {
                 if (sampleProduct[sampleTypeId]) {
                    let profilesToRemove = masterDict[deselectedUuid].profiles;
                    sampleProduct[sampleTypeId] = sampleProduct[sampleTypeId].filter(profile => !profilesToRemove.includes(profile));
                    if (sampleProduct[sampleTypeId].length === 0) {
                       delete sampleProduct[sampleTypeId];
                    }
                 }
              });
              uniqueSampleTypeIds = uniqueSampleTypeIds.filter(id => {
                 return Object.keys(masterDict).some(uuid => {
                    return uuid !== deselectedUuid && masterDict[uuid].sampleTypeIds.includes(id);
                 });
              });

              allTests = allTests.filter(test => {
                 return Object.keys(masterDict).some(uuid => {
                    return uuid !== deselectedUuid && masterDict[uuid].tests.includes(test);
                 });
              });

              selectedItems = selectedItems.filter(item => item.uuid !== deselectedUuid);
              delete masterDict[deselectedUuid];
              updateSampleListView();
              updateBarcodeTable();
              updateTotalAmount();
              var selectedOptions = $('#selTest').val();
              if (selectedOptions && selectedOptions.length === 1) {
                  var a=selectedOptions;
                 var selectedOptionDetails = selectedOptions[0].split('|');
                 var selectedProductId = selectedOptionDetails[1];
                 var isMyProfile = selectedOptionDetails[12];
                 if (isMyProfile === '0' && $('#selTest').val() && $('#selTest').val().length === 1 && $('#selTest').val() && $('#selTest').val()[0].split('|')[12] == '0' && $('#selLead').val().split('|')[0] == 0 && document.getElementById("selref").value.trim() == 0 ) {
                    walkinValidecoupon(selectedProductId);
                 } else {
                    $('#couponContainerspan').empty();
                    $('#couponContainerspan').hide();
                    $('#txtcoupon').val('')
                    CoupnCodeApplied = false;
                 }
              } else {
                 $('#couponContainerspan').empty();
                 $('#couponContainerspan').hide();
                 $('#txtcoupon').val('')
                 CoupnCodeApplied = false;
              }


           }
        }

