        function updateBarcodeTable() {
           const barcodeTableContainer = $('#barcodeTableContainer');
           const existingTable = barcodeTableContainer.find('.barcode-table');
           const dvbarcode = $('#subBarcodediv');
           const checkidcoupon = $('#invcoup').val();

           if (uniqueSampleTypeIds.length === 0) {
              existingTable.remove();
