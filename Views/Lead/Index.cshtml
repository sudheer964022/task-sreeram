    }

         function updateDiscountDisplay() {
            if (rateType != 2 || isDiscountEligible == 0) {
                document.getElementById('discountAppliedCard').classList.add('hidden');
                document.getElementById('discountAppliedCard').style.display = 'none';
                document.getElementById('unlockDiscountCard').classList.add('hidden');
