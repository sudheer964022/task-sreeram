    }

    @@keyframes slideInUp {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Responsive adjustments */
    @@media (max-width: 768px) {
        .space-y-2 {
            gap: 0.4rem;
        }

        #discountAppliedCard {
            font-size: 0.75rem;
        }

