        function validateGender(test, gender) {
           var isValid = false;
           if (gender === "MALE" && test.maleSAge !== "" && test.maleEAge !== "") {
              isValid = true;
           } else if (gender === "FEMALE" && test.femaleSAge !== "" && test.femaleEAge !== "") {
              isValid = true;
           } else if (gender === "OTHER") {
              isValid = (test.maleSAge !== "" && test.maleEAge !== "") ||
                        (test.femaleSAge !== "" && test.femaleEAge !== "");
           }
           return {
              isValid: isValid
           };
        }

        function validateAge(test, gender, ageInDays) {
           var minAge, maxAge;
           if (gender === "MALE") {
              minAge = parseInt(test.maleSAge);
              maxAge = parseInt(test.maleEAge);
           } else if (gender === "FEMALE") {
              minAge = parseInt(test.femaleSAge);
              maxAge = parseInt(test.femaleEAge);
           } else {
              if (test.maleSAge !== "" && test.maleEAge !== "") {
                 minAge = parseInt(test.maleSAge);
                 maxAge = parseInt(test.maleEAge);
              } else {
                 minAge = parseInt(test.femaleSAge);
                 maxAge = parseInt(test.femaleEAge);
              }
           }
           return {
              isValid: ageInDays >= minAge && ageInDays <= maxAge,
              minAge: minAge,
              maxAge: maxAge
           };
        }

        function convertToDays(age, ageType) {
           switch (ageType) {
              case 'Y':
                 return age * 365;
              case 'M':
                 return age * 30;
              case 'D':
                 return parseInt(age);
              default:
                 return null;
           }
        }

        function convertDaysToReadableAge(days) {
           if (days >= 365) {
              var years = Math.floor(days / 365);
              return years + " year" + (years > 1 ? "s" : "");
           } else if (days >= 30) {
              var months = Math.floor(days / 30);
              return months + " month" + (months > 1 ? "s" : "");
           } else {
              return days + " day" + (days > 1 ? "s" : "");
           }
        }

