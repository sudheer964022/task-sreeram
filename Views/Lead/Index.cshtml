                 row.fadeOut(300, function () {
                    $(this).remove();
                    if (table.find('tr').length === 0) {
                       table.remove();
                       dvbarcode.hide();
                    }
                 });
              }
           });
           if (table.find('tr').length > 0) {
              dvbarcode.show();
           } else {
              dvbarcode.hide();
           }

           updateProfileTable();
           updateTotalAmount();
