        color: red;
        font-size: 0.75rem;
        margin-top: 0.25rem;
        display: none;
    }

    .input-error {
        border-color: red;
    }

    .container {
        max-width: 100%;
    }

    .select2-container--default .select2-selection--single {
        background-color: #fff;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        border: 1px solid #e4e6f6 !important;
        border-radius: 4px;
    }

    .checkboxes {
        display: flex;
        flex-direction: column;
        background-color: #ffffff;
        border-radius: 4px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    .checkboxes__row {
        display: flex;
    }

        .checkboxes__row:not(:last-child) {
            border-bottom: 1px solid #e2e8f0;
        }

    .checkboxes__item {
        width: 100%;
    }

    .checkbox.style-h {
        display: block;
        position: relative;
        cursor: pointer;
        user-select: none;
    }

        .checkbox.style-h input {
            position: absolute;
            opacity: 0;
            cursor: pointer;
            height: 0;
            width: 0;
        }

            .checkbox.style-h input:checked ~ .checkbox__checkmark {
                background-color: #4299e1;
            }

                .checkbox.style-h input:checked ~ .checkbox__checkmark:after {
                    opacity: 1;
                    top: -3px;
                    left: 7px;
                    border-color: #ffffff;
                }

            .checkbox.style-h input:checked ~ .checkbox__body {
                background-position: 0 0;
                color: #ffffff;
                background-color: #3795e29c;
            }

        .checkbox.style-h:hover input ~ .checkbox__checkmark {
            background-color: #63b3ed;
        }

        .checkbox.style-h:hover input:checked ~ .checkbox__checkmark {
            background-color: #3182ce;
        }

        .checkbox.style-h .checkbox__checkmark {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            left: 15px;
            height: 22px;
            width: 22px;
            background-color: #e2e8f0;
            ;
            transition: background-color 0.25s ease;
            border-radius: 4px;
            box-shadow: inset 2px 2px 4px rgba(0, 0, 0, 0.1), inset -2px -2px 4px rgba(255, 255, 255, 0.4);
        }

            .checkbox.style-h .checkbox__checkmark:after {
                content: "";
                position: absolute;
                left: 10px;
                top: -15px;
                width: 10px;
                height: 20px;
                border: solid #ffffff;
                border-width: 0 4px 4px 0;
                transform: rotate(45deg);
                opacity: 0;
                transition: opacity 0.25s ease, top 0.25s ease;
            }

        .checkbox.style-h .checkbox__body {
            color: #2d3748;
            line-height: 1.4;
            font-size: 16px;
            transition: font-weight 0.25s ease;
            font-weight: bold;
            background-size: 200% 100%;
            background-position: 100% 0;
            padding: 4px;
            padding-left: 51px;
            border-radius: 4px;
            box-shadow: 2px 2px 5px rgba(0, 0, 0, 0.2);
            transition: box-shadow 0.25s ease, background 1s ease, color 0.25s ease;
            padding-right: 20px;
        }

    .input-container {
        position: relative;
        width: full;
    }

        .input-container input {
            width: 100%;
            padding: 0.5rem 0.75rem;
            border: 1px solid #d1d5db;
            border-radius: 0.25rem;
            transition: all 0.3s ease;
        }

            .input-container input:focus {
                outline: none;
                border-color: #3b82f6;
                box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
            }

    .error-message {
        position: absolute;
        bottom: -1.5rem;
        left: 0;
        color: #ef4444;
        font-size: 0.75rem;
        opacity: 0;
        transform: translateY(-10px);
        transition: all 0.3s ease;
    }

    .input-container input.error {
        border-color: #ef4444;
    }

    .input-container input:focus + .error-message,
    .input-container input.show-error + .error-message {
        opacity: 1;
        transform: translateY(0);
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.7;
        }
    }

    #discountPercentageLabel {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    .tier-item.active {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-color: #667eea !important;
        transform: scale(1.02);
    }

        .tier-item.active .text-purple-600,
        .tier-item.active .text-gray-600 {
            color: white !important;
        }

    #discountAppliedCard {
        animation: slideInUp 0.3s ease-out;
    }

    #unlockDiscountCard {
