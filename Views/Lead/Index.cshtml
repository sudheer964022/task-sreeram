        function getSampleType(productId, callback) {
           var pUrl = '@Url.Action("producttestlist")';
           $.ajax({
              type: "POST",
              url: pUrl,
              data: {
                 ProductId: productId
              },
              contentType: "application/x-www-form-urlencoded",
              dataType: "json",
              success: function (response) {
                 if (response && response.d.length) {
                    callback(response);
                 } else {
                    alert("No sample type found for product: " + productId);
                 }
              },
              error: function (response) {
                 alert("Error fetching sample type for product: " + productId);
              }
           });
        }

        function checkRBSPPBSConflict(newProductId, selectedOptions) {
           const conflictIds = ['165', '147'];
           if (conflictIds.includes(newProductId)) {
              const otherConflictId = conflictIds.find(id => id !== newProductId);
              if (selectedOptions.some(option => {
                    const optionDetails = option.split('|');
                    return optionDetails[1] === otherConflictId;
                 })) {
                 return true;
              }
           }
           return false;
        }

        function checkBalanceForProduct(product) {
           var currentTotal = parseFloat($('#amt').text().split(' ')[0]) || 0;
           var newTotal = currentTotal + parseFloat(product.billedAmount);

           if (newTotal > window.availableBalance) {
              alert("Adding " + product.productCode + " (" + parseFloat(product.billedAmount).toFixed(globalDecimalPoints) + " " + product.currencyCode + ") would exceed your available balance. Your current balance is " +
                 parseFloat(window.availableBalance).toFixed(globalDecimalPoints) + " " + window.balanceCurrency);
              return false;
           }

           return true;
        }

