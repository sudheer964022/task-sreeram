        function initializeTierDisplay() {
            if (discountSlabs.length === 0) return;

            discountSlabs.forEach((slab, index) => {
                let tierId = `tier${index + 1}`;
                let amountId = `tier${index + 1}-amount`;
                let tierElement = document.getElementById(tierId);
                let amountElement = document.getElementById(amountId);

                if (tierElement && amountElement) {
                    let displayAmount = slab.thresholdAmount.toFixed(globalDecimalPoints) + ' ' + globalCurrencyCode;
                    amountElement.textContent = displayAmount + '+';

                    let percentageDiv = tierElement.querySelector('.text-purple-600');
                    if (percentageDiv) {
                        percentageDiv.textContent = slab.discountPercentage + '%';
                    }
                }
            });

            let tier3 = document.getElementById('tier3');
            if (tier3) tier3.style.display = 'none';
        }

            function calculateApplicableDiscount(testAmount) {
                let applicableDiscount = {
                    percentage: 0,
                    thresholdAmount: 0,
                    nextThreshold: null,
                    amountNeeded: 0,
                    tier: 0,
                    nextTierIndex: -1
                };

                if (discountSlabs.length === 0) return applicableDiscount;

                for (let i = discountSlabs.length - 1; i >= 0; i--) {
                    if (testAmount >= discountSlabs[i].thresholdAmount) {
                        applicableDiscount.percentage = discountSlabs[i].discountPercentage;
                        applicableDiscount.thresholdAmount = discountSlabs[i].thresholdAmount;
                        applicableDiscount.tier = i + 1;

                        if (i < discountSlabs.length - 1) {
                            applicableDiscount.nextThreshold = discountSlabs[i + 1];
                            applicableDiscount.nextTierIndex = i + 1;
                            applicableDiscount.amountNeeded = discountSlabs[i + 1].thresholdAmount - testAmount;
                        }
                        break;
                    } else if (i === 0) {
                        applicableDiscount.nextThreshold = discountSlabs[i];
                        applicableDiscount.nextTierIndex = i;
                        applicableDiscount.amountNeeded = discountSlabs[i].thresholdAmount - testAmount;
                    }
                }

                return applicableDiscount;
            }

