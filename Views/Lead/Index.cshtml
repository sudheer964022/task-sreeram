        function setupBarcodeValidation() {
           $('#barcodeTableContainer').on('input', '.barcode-input', function (e) {
              let input = $(this);
              let value = input.val();
              let newValue = value.toUpperCase().replace(/[^A-Z0-9]/g, '');
              newValue = newValue.slice(0, 10);
              if (value !== newValue) {
                 input.val(newValue);
              }
              if (newValue.length === 8 || newValue.length === 10) {
                 input.removeClass('error');
                 input.removeAttr('title');
                 if (newValue.length === 10) {
                    if (input.hasClass('enter-barcode')) {
                       let nextInput = input.closest('tr').find('.reenter-barcode');
                       nextInput.focus();
                    } else if (input.hasClass('reenter-barcode')) {
                       let nextRow = input.closest('tr').next();
                       if (nextRow.length) {
                          nextRow.find('.enter-barcode').focus();
                       }
                    }
                 }
              } else {
                 input.addClass('error');
                 input.attr('title', 'Barcode must be either 8 or 10 characters long');
              }
              const sampleTypeId = input.data('sample-type-id');
              const enteredBarcode = $(`.enter-barcode[data-sample-type-id="${sampleTypeId}"]`).val();
              const reenteredBarcode = $(`.reenter-barcode[data-sample-type-id="${sampleTypeId}"]`).val();
              if (enteredBarcode && reenteredBarcode) {
                 const barcodeInputs = $(`.barcode-input[data-sample-type-id="${sampleTypeId}"]`);
                 if (enteredBarcode !== reenteredBarcode) {
                    barcodeInputs.addClass('error');
                    barcodeInputs.attr('title', 'Barcodes do not match');
                 } else if (enteredBarcode.length === reenteredBarcode.length && (enteredBarcode.length === 8 || enteredBarcode.length === 10)) {
                    barcodeInputs.removeClass('error');
                    barcodeInputs.removeAttr('title');
                 }
              }
              if (newValue.length === 8 || newValue.length === 10) {
                 let isDuplicate = false;
                 $('.enter-barcode').each(function () {
                    let otherInput = $(this);
                    let otherSampleTypeId = otherInput.data('sample-type-id');
                    let otherBarcode = otherInput.val();

                    if (otherSampleTypeId !== sampleTypeId && otherBarcode === newValue) {
                       isDuplicate = true;
                       return false;
                    }
                 });

                 if (isDuplicate) {
                    input.addClass('error');
                    input.attr('title', 'Duplicate barcode detected for different sample type');
                    input.closest('tr').find('.reenter-barcode').addClass('error').attr('title', 'Duplicate barcode detected for different sample type');
                 } else {
                    if (input.attr('title') === 'Duplicate barcode detected for different sample type') {
                       input.removeClass('error');
                       input.removeAttr('title');
                       input.closest('tr').find('.reenter-barcode').removeClass('error').removeAttr('title');
                    }
                 }
              }
           });
        }

