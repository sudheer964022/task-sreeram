    function calculateTotal() {
        const totalAmountSpan = document.getElementById('totDisPrice');
        const testAmount = parseFloat(document.getElementById('amt').innerHTML.split(' ')[0]) || 0;
        var customerMode = parseInt(document.getElementById('customerMode').value);
        var paymentType = parseInt(document.getElementById('paymentType').value);
        var txtHomeCharge = document.getElementById('txtHomeCharge').value;
        var homeCharge = 0;

        if ((customerMode == '0' || customerMode == '') && (paymentType == '2' || paymentType == '')) {
            var dis = $('#seldistance').val();
            homeCharge = dis != '0' ? parseFloat(document.getElementById('txtHomeCharge').value.split(' ')[0]) || 0 : 0;
        } else if (customerMode == '2' && txtHomeCharge && txtHomeCharge.split(' ')[0] != '0') {
            homeCharge = parseFloat(txtHomeCharge.split(' ')[0]) || 0;
        } else {
            var dis = $('#seldistance').val();
            homeCharge = dis != '0' ? parseFloat(document.getElementById('txtHomeCharge').value.split(' ')[0]) || 0 : 0;
        }

        let discountAmount = 0;
        let total = testAmount + homeCharge;

        if (rateType == 2) {
            if (isCRSLead && crsPartnerId > 0) {
                discountAmount = crsDiscount || 0;
            } else if (appliedDiscount.enabled && appliedDiscount.percentage > 0) {
                discountAmount = (testAmount * appliedDiscount.percentage) / 100;
            }
            total = (testAmount - discountAmount) + homeCharge;
        }

        if (CoupnCodeApplied) {
            totalAmountSpan.textContent = (0).toFixed(globalDecimalPoints) + ' ' + globalCurrencyCode;
        } else {
            totalAmountSpan.textContent = total.toFixed(globalDecimalPoints) + ' ' + globalCurrencyCode;
        }
    }

          function updateTotalAmount() {
                var total = 0.00;
                var currencyCode = '';
                var maxDecimalPoints = 2;

                for (var productId in masterDict) {
                    var product = selectedItems.find(item => item.uuid === productId);
                    if (product) {
                        total += parseFloat(product.billedAmount);
                        currencyCode = product.currencyCode;
                        maxDecimalPoints = parseInt(product.decimalpoints);
                    }
                }

                total = parseFloat(total.toFixed(maxDecimalPoints));

                $({
                    numberValue: parseFloat($('#amt').text())
                }).animate({
                    numberValue: total
                }, {
                    duration: 500,
                    easing: 'swing',
                    step: function () {
                        $('#amt').text(this.numberValue.toFixed(maxDecimalPoints) + ' ' + currencyCode);
                    },
                    complete: function () {
                        $('#amt').text(total.toFixed(maxDecimalPoints) + ' ' + currencyCode);
                        calculateTotal();
                    }
                });

                if (total > window.availableBalance && IsCashCLient == 1) {
                    alert("The total amount exceeds your available balance. Please adjust your selection.");
                }
            }

