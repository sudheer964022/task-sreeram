        function fetchProductData(id, leadclientid) {
           return new Promise((resolve, reject) => {
              pUrl = '@Url.Action("Getbooking", "Lead")';
              $.ajax({
                 type: "POST",
                 url: pUrl,
                 data: {
                    leadId: 0,
                    productId: id,
                    blockId: 3,
                    leadclientid: leadclientid
                 },
                 contentType: "application/x-www-form-urlencoded",
                 dataType: "json",
                 success: function (response) {
                    if (response.data && response.data.length > 0) {
                       var matchingValues = [];
                       var Rlst = response.data;

                       Rlst.forEach(function (item) {
                          var selectElement = $('#selTest');
                          var allOptions = selectElement.find('option');

                          allOptions.each(function () {
                             var optionValue = $(this).val();
                             var optionParts = optionValue.split('|')
                             if (
                                optionParts[1] == item.column1 && 
                                optionParts[12] == item.column12  
                             ) {
                                matchingValues.push(optionValue);
                             }
                          });
                       });

                       resolve(matchingValues);
                    } else {
                       resolve([]);
                    }
                 },
                 error: function (xhr, status, error) {
                    console.error("Error for ID: " + id, error);
                    reject(error);
                 }
              });
           });
        }

        function processAllProducts(ids, leadclientid) {
           previousSelection = [];
           masterDict = {};
           selectedItems = [];
           uniqueSampleTypeIds = [];
           allTests = [];

           const promises = ids.map(id => fetchProductData(id, leadclientid));
           Promise.all(promises)
              .then(results => {
                 const allMatchingValues = [...new Set(results.flat())];
                 const testProfileDropdown = $("#selTest");
                 if (!testProfileDropdown.hasClass("select2-hidden-accessible")) {
                    testProfileDropdown.select2();
                 }
                 if (allMatchingValues.length > 0) {
                    $('#selTest')
                       .val(allMatchingValues)
                       .trigger('change');

                 } else {
                    alert('Test details not found, please check the MIS page or contact the lab team.');
                 }
              })
              .catch(error => {
                 console.error("Error processing products:", error);
              });
        }

