        var itiB2C = null;
        var phoneIsValidB2C = false;
        var isOtherCountryB2C = false;
        var mobileErrorMap = ["Invalid number","Invalid country code","Too short","Too long","Invalid number"];

        function initMobileITI() {
            var phoneInput = document.getElementById('txtMob');
            if (!phoneInput || typeof window.intlTelInput === 'undefined') return;
            
            // Prevent double initialization which causes duplicate flag buttons
            if (itiB2C) return;

            var countryISOMap = { 4:'ae', 2:'bh', 3:'om', 5:'sa', 1:'bh' };
            var clCntryInt = parseInt('@Accessor.HttpContext.Session.GetInt32("CountryId")', 10) || 4;
            var defaultCountry = countryISOMap[clCntryInt] || 'ae';
            itiB2C = window.intlTelInput(phoneInput, {
                initialCountry: defaultCountry,
                nationalMode: true,
                separateDialCode: true,
                preferredCountries: ['ae','bh','om','sa','in','gb','us','pk','ph','eg','jo','kw','qa','bd','lk','np'],
                dropdownContainer: document.body,
                utilsScript: "https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.21/js/utils.js"
            });
            phoneInput.addEventListener('input', function() {
                this.value = this.value.replace(/[^0-9]/g, '');
                validateMobileCustom();
            });
            phoneInput.addEventListener('blur', validateMobileCustom);
            phoneInput.addEventListener('countrychange', function() {
                this.value = '';
                resetPhoneValidationB2C();
            });
        }

        function validateMobileCustom() {
            if (isOtherCountryB2C) return validateOtherPhone();
            var phoneInput = document.getElementById('txtMob');
            var feedbackDiv = document.getElementById('phoneFeedbackB2C');
            var validIcon = document.getElementById('phoneValidationIcon');
            if (!phoneInput || !itiB2C) return false;
            var val = phoneInput.value.trim();
            phoneInput.classList.remove('input-error','input-valid');
            if (feedbackDiv) feedbackDiv.style.display = 'none';
            if (validIcon) validIcon.style.display = 'none';
            if (!val) { phoneIsValidB2C = false; return false; }
            if (itiB2C.isValidNumber()) {
                phoneInput.classList.add('input-valid');
                if (validIcon) { validIcon.innerHTML = '<i class="fas fa-check-circle" style="color:#10b981;"></i>'; validIcon.style.display = 'block'; }
                if (feedbackDiv) { feedbackDiv.innerHTML = '<span style="color:#10b981;"><i class="fas fa-check-circle"></i> Valid</span>'; feedbackDiv.style.display = 'block'; }
                phoneIsValidB2C = true;
                return true;
            } else {
                var errorCode = itiB2C.getValidationError();
                var errorMsg = mobileErrorMap[errorCode] || "Invalid number";
                if (errorCode === 2 && window.intlTelInputUtils) {
                    try {
                        var cd = itiB2C.getSelectedCountryData();
                        var ex = intlTelInputUtils.getExampleNumber(cd.iso2, false, 0).replace(/[^0-9]/g,'');
                        if (ex && ex.length > val.length) errorMsg = 'Enter ' + (ex.length - val.length) + ' more digit(s)';
                    } catch(e) {}
                }
                phoneInput.classList.add('input-error');
                if (validIcon) { validIcon.innerHTML = '<i class="fas fa-times-circle" style="color:#ef4444;"></i>'; validIcon.style.display = 'block'; }
                if (feedbackDiv) { feedbackDiv.innerHTML = '<span style="color:#ef4444;"><i class="fas fa-exclamation-circle"></i> ' + errorMsg + '</span>'; feedbackDiv.style.display = 'block'; }
                phoneIsValidB2C = false;
                return false;
            }
        }

        function validateMobileITI() { return validateMobileCustom(); }

        function resetPhoneValidationB2C() {
            var phoneInput = document.getElementById('txtMob');
            var feedbackDiv = document.getElementById('phoneFeedbackB2C');
            var validIcon = document.getElementById('phoneValidationIcon');
            if (phoneInput) phoneInput.classList.remove('input-error','input-valid');
            if (feedbackDiv) feedbackDiv.style.display = 'none';
            if (validIcon) validIcon.style.display = 'none';
            phoneIsValidB2C = false;
        }

        function toggleOtherCountryB2C() {
            var checkbox = document.getElementById('chkOtherCountry');
            var standardContainer = document.getElementById('phoneStandardContainer');
            var otherContainer = document.getElementById('phoneOtherContainer');
            isOtherCountryB2C = checkbox.checked;
            if (isOtherCountryB2C) {
                standardContainer.style.display = 'none';
                otherContainer.style.display = 'block';
                if (itiB2C) document.getElementById('txtMob').value = '';
                resetPhoneValidationB2C();
                document.getElementById('otherPhoneNumber').value = '';
                document.getElementById('otherPhoneNumber').focus();
            } else {
                standardContainer.style.display = 'block';
                otherContainer.style.display = 'none';
                document.getElementById('otherPhoneNumber').value = '';
                resetPhoneValidationB2C();
            }
            phoneIsValidB2C = false;
        }

        function validateOtherPhone() {
            var val = document.getElementById('otherPhoneNumber').value.trim();
            var feedbackDiv = document.getElementById('phoneFeedbackB2C');
            phoneIsValidB2C = val.length > 0;
            if (feedbackDiv) {
                feedbackDiv.innerHTML = phoneIsValidB2C ? '<span style="color:#10b981;"><i class="fas fa-check-circle"></i> Number entered</span>' : '';
                feedbackDiv.style.display = phoneIsValidB2C ? 'block' : 'none';
            }
            return phoneIsValidB2C;
        }

        function getFullMobileNumber() {
            if (isOtherCountryB2C) return document.getElementById('otherPhoneNumber').value.trim();
            return itiB2C ? itiB2C.getNumber() : '';
        }

        $('#txtNIN1').on('keypress keyup', function (e) {
           var ssd = $(this).val();
           var NINlength = $('#txtNIN1').val().length;
           var NINValue = $('#txtNIN1').val();
           var isEmptyNIN = NINValue.trim() === '';
           var isTraveller = $('#chktravel').is(':checked');
           if (isEmptyNIN && isTraveller) {
              $("#lbldigitmsg").hide();
           } else if (isEmptyNIN && !isTraveller) {
              $("#lbldigitmsg").show();
           } else {
              $("#lbldigitmsg").show();
           }

                 if (clCntry == '2') {
                    let NINValue = $('#txtNIN1').val();
                    let NINlength = NINValue.length;
                    if (e.which != 8 && e.which != 0 && e.which !== 45 && (e.which < 48 || e.which > 57)) {
                        return false;
                    }
                    if (NINlength >= 10) {
                        if ($.isNumeric(NINValue)) {
                            $("#lbldigitmsg").hide();
                            return false;
                        } else {
                            alert("Only numeric values are allowed");
                            $("#lbldigitmsg").hide();
                            return false;
                        }
                    }

                    if (NINlength === 9 || NINlength === 10) {
                        if ($.isNumeric(NINValue)) {
                            $("#lbldigitmsg").hide();
                            return true;
                        } else {
                            alert("Only numeric values are allowed");
                            $("#lbldigitmsg").hide();
                            return false;
                        }
                    }

                    return true;
                }

            if (clCntry == '5') {
              if (e.which != 8 && e.which != 0 && e.which !== '-' && (e.which < 48 || e.which > 57)) {
                 $('#txtNIN1').remove(e);
                 return false;
              }

              if (NINlength == "10") {
                 if ($.isNumeric(NINValue)) {
                    $("#lbldigitmsg").hide();
                    return false;
                 } else {
                    alert("Not Allow");
                    $("#lbldigitmsg").hide();
                 }
              }
              if (NINlength < "10" && NINlength > "10") {
                 if ($.isNumeric(NINValue)) {
                    $("#lbldigitmsg").hide();
                    return false;
                 } else {
                    alert("Not Allow");
                    $("#lbldigitmsg").hide();
                 }
                 $("#lbldigitmsg").show();
                 return false;
              }
           }

            if (clCntry == '3') {
              if (e.which != 8 && e.which != 0 && e.which !== '-' && (e.which < 48 || e.which > 57)) {
                 return false;
              }

              if (NINlength == "8") {
                 if ($.isNumeric(NINValue)) {
                    $("#lbldigitmsg").hide();
                    return false;
                 } else {
                    alert("Not Allow");
                    $("#lbldigitmsg").hide();
                 }
              }
              if (NINlength < "8" && NINlength > "8") {
                 if ($.isNumeric(NINValue)) {
                    $("#lbldigitmsg").hide();
                    return false;
                 } else {
