        document.addEventListener("DOMContentLoaded", function () {
           const dobPicker = document.getElementById("dobPicker");
           const txtAge = document.getElementById("txtAge");
           const selAgeTy = document.getElementById("selAgeTy");
           const maxYears = 120;
           const maxMonths = maxYears * 12;
           const maxDays = Math.floor(maxYears * 365.25);

           function parseDate(input) {
              const parts = input.split("/");
              if (parts.length === 3) {
                 const day = parseInt(parts[0], 10);
                 const month = parseInt(parts[1], 10) - 1;
                 const year = parseInt(parts[2], 10);
                 return new Date(year, month, day);
              }
              return null;
           }

           function formatDate(date) {
              const day = String(date.getDate()).padStart(2, '0');
              const month = String(date.getMonth() + 1).padStart(2, '0');
              const year = date.getFullYear();
              return `${day}/${month}/${year}`;
           }

           function calculateAge(dob) {
              const dobDate = parseDate(dob);
              const today = new Date();
              if (!dobDate || isNaN(dobDate)) return {
                 years: 0,
                 months: 0,
                 days: 0
              };

              const diffYears = today.getFullYear() - dobDate.getFullYear();
              const diffMonths = today.getMonth() - dobDate.getMonth();
              const diffDays = today.getDate() - dobDate.getDate();

              let ageYears = diffYears;
              let ageMonths = diffMonths + ageYears * 12;
              let ageDays = Math.floor((today - dobDate) / (1000 * 60 * 60 * 24));

              if (diffMonths < 0 || (diffMonths === 0 && diffDays < 0)) {
                 ageYears--;
                 ageMonths = ageYears * 12 + diffMonths;
              }

              return {
                 years: ageYears,
                 months: ageMonths,
                 days: ageDays
              };
           }

           function calculateDOB(age, ageType) {
              const today = new Date();
              const dob = new Date(today);

              switch (ageType) {
                 case 'Y':
                    dob.setFullYear(today.getFullYear() - age);
                    break;
                 case 'M':
                    const years = Math.floor(age / 12);
                    const months = age % 12;
                    dob.setFullYear(today.getFullYear() - years);
                    dob.setMonth(today.getMonth() - months);
                    break;
                 case 'D':
                    dob.setDate(today.getDate() - age);
                    break;
              }

              if (ageType === 'Y' || ageType === 'M') {
                 dob.setDate(1);
              }

              return formatDate(dob);
           }

           function updateAgeAndType(dob) {
              const {
                 years,
                 months,
                 days
              } = calculateAge(dob);
              if (years >= 1) {
                 selAgeTy.value = "Y";
                 txtAge.value = years;
              } else if (months >= 1) {
                 selAgeTy.value = "M";
                 txtAge.value = months;
              } else {
                 selAgeTy.value = "D";
                 txtAge.value = days;
              }
              setAgeConstraints();
           }

           function getMaxAge(ageType) {
              switch (ageType) {
                 case "Y":
                    return maxYears;
                 case "M":
                    return maxMonths;
                 case "D":
                    return maxDays;
                 default:
                    return txtAge.value;
              }
           }

           function setAgeConstraints() {
              const maxAge = getMaxAge(selAgeTy.value);
              txtAge.setAttribute("max", maxAge);
              return maxAge;
           }

           function formatAgeValue(value, maxAge) {
              value = value.replace(/[^\d]/g, '');
              value = value.replace(/^0+/, '');

              if (!value) {
                 return '';
              }

              let numValue = parseInt(value, 10);
              numValue = Math.min(numValue, maxAge);

              return numValue.toString();
           }

           function validateAgeInput() {
              const maxAge = setAgeConstraints();
              const currentValue = txtAge.value;

              if (!currentValue) {
                 return;
              }

              const formattedValue = formatAgeValue(currentValue, maxAge);

              if (formattedValue !== currentValue) {
                 txtAge.value = formattedValue;
              }
              if (formattedValue) {
                 const ageValue = parseInt(formattedValue, 10);
                 const dob = calculateDOB(ageValue, selAgeTy.value);

              }
           }
           txtAge.addEventListener("keypress", function (e) {
              if (!/^\d$/.test(e.key)) {
                 e.preventDefault();
              }
           });
           dobPicker.addEventListener("change", function () {
              const dob = dobPicker.value;
              if (dob) {
                 updateAgeAndType(dob);
              }
           });
           selAgeTy.addEventListener("change", function () {
              setAgeConstraints();
              validateAgeInput();
           });
           txtAge.addEventListener("input", function (e) {
              validateAgeInput();
           });
           txtAge.addEventListener("paste", function (e) {
              e.preventDefault();
              const pastedText = (e.clipboardData || window.clipboardData).getData('text');
              const formattedValue = formatAgeValue(pastedText, getMaxAge(selAgeTy.value));
              txtAge.value = formattedValue;
              validateAgeInput();
           });
           setAgeConstraints();
        });

    function updateAgeLabel() {
        var dob = document.getElementById('dobPicker').value;
        var lbl = document.getElementById('ageDisplayLabel');
        if (!dob) { if (lbl) lbl.textContent = ''; return; }

        var parts = dob.split('/');
        if (parts.length !== 3) return;
        var dobDate = new Date(parts[2], parts[1] - 1, parts[0]);
        var today = new Date();

        var years = today.getFullYear() - dobDate.getFullYear();
        if (today.getMonth() < dobDate.getMonth() ||
           (today.getMonth() === dobDate.getMonth() && today.getDate() < dobDate.getDate())) {
            years--;
        }

        var months = (today.getFullYear() - dobDate.getFullYear()) * 12 + (today.getMonth() - dobDate.getMonth());
        if (today.getDate() < dobDate.getDate()) months--;

        var days = Math.floor((today - dobDate) / (1000 * 60 * 60 * 24));

        var ageVal, ageType, ageText;
        if (years >= 1) {
            ageVal = years; ageType = 'Y';
            ageText = 'Age: ' + years + ' year' + (years > 1 ? 's' : '');
        } else if (months >= 1) {
            ageVal = months; ageType = 'M';
            ageText = 'Age: ' + months + ' month' + (months > 1 ? 's' : '');
        } else {
            ageVal = days; ageType = 'D';
            ageText = 'Age: ' + days + ' day' + (days > 1 ? 's' : '');
        }

        if (lbl) lbl.textContent = ageText;
        document.getElementById('txtAge').value = ageVal;
        document.getElementById('selAgeTy').value = ageType;
    }

